# Default: normalize all text files to LF in the repo
* text=auto eol=lf

# Explicitly force LF for server-side files (CRLF breaks bash and systemd)
*.sh        text eol=lf
*.service   text eol=lf
nginx.conf  text eol=lf
nginx.conf.example text eol=lf
*.py        text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.js        text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf
*.env       text eol=lf

# Binary files — never touch line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.pdf  binary
*.zip  binary
*.db   binary
