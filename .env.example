# Copy this file to .env and fill in your values
# Never commit .env to git

SECRET_KEY=generate-a-long-random-string-here
FLASK_ENV=development
KECHAFA_DB=kechafa.db
DEFAULT_LANGUAGE=fr

# AI (OpenRouter)
OPENROUTER_API_KEY=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
OPENROUTER_FALLBACK_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=openrouter/free
OPENROUTER_MAX_TOKENS=512
OPENROUTER_APP_URL=http://localhost:5000
OPENROUTER_APP_TITLE=Academic Kechafa
ENABLE_REAL_AI=true

# Limits
MAX_CONTENT_LENGTH_MB=50

# Email — Brevo SMTP (free 300/day — brevo.com > SMTP & API)
MAIL_SERVER=live.smtp.mailtrap.io
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=your_email@address.com
MAIL_PASSWORD=your_password
MAIL_DEFAULT_SENDER=Only Scouts Academy <noreply@onlyscouts.com>

# Alternative (Brevo SMTP):
# MAIL_SERVER=smtp-relay.brevo.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USE_SSL=false
# MAIL_USERNAME=your_brevo_login@example.com
# MAIL_PASSWORD=your_brevo_smtp_password
# MAIL_DEFAULT_SENDER=Only Scouts Academy <noreply@onlyscouts.com>

# Google OAuth (Sign in with Google)
# Get these from https://console.cloud.google.com > APIs & Services > Credentials
# Add http://localhost:5000/google/callback as an Authorized Redirect URI
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret-here

# SSL (local dev only -- leave empty in production)
SSL_CERT_FILE=
SSL_KEY_FILE=
FLASK_SSL_MODE=
PREFERRED_URL_SCHEME=http
